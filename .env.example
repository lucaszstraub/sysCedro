# =============================================================================
# SysCedro WMS — Credenciais (copie para .env na raiz do projeto)
# =============================================================================
# cp .env.example .env
#
# O arquivo .env NÃO vai para o git (.gitignore). Preencha com os valores do
# painel Supabase: Project Settings → Database / API
# =============================================================================

# --- Opção A: Session pooler (IPv4 — recomendado para Electron) ---
# Project → Connect → Session pooler → copie a URI
DATABASE_POOLER_URL=postgresql://postgres.gzveuamcqokfbgyvxbed:SUA_SENHA@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# --- Opção B: conexão direta (somente IPv6 ou add-on IPv4) ---
# DATABASE_URL=postgresql://postgres:SUA_SENHA@db.gzveuamcqokfbgyvxbed.supabase.co:5432/postgres

# --- Opção C: campos separados (senha literal, sem % encoding) ---
# DB_HOST=aws-N-REGIAO.pooler.supabase.com
# DB_PORT=5432
# DB_USER=postgres.gzveuamcqokfbgyvxbed
# DB_PASSWORD=sua_senha
# DB_NAME=postgres

# SSL obrigatório no Supabase
DB_SSL=true

# Modo nuvem: não tenta CREATE DATABASE (use true no Supabase)
DB_CLOUD=true

# Modo híbrido: PostgreSQL local + sincronização com Supabase na inicialização.
# Ativado automaticamente quando DATABASE_POOLER_URL está definido.
# DB_HYBRID=true

# PostgreSQL local (modo híbrido / offline)
# DB_LOCAL_HOST=localhost
# DB_LOCAL_PORT=5432
# DB_LOCAL_USER=postgres
# DB_LOCAL_PASSWORD=root
# DB_LOCAL_NAME=sys_cedro_wms

# --- Supabase API (Project Settings → API) ---
SUPABASE_URL=https://gzveuamcqokfbgyvxbed.supabase.co
SUPABASE_PUBLISHABLE_KEY=sua_publishable_key
SUPABASE_SECRET_KEY=sua_secret_key
# Compatibilidade com código que usa service_role:
SUPABASE_SERVICE_ROLE_KEY=sua_secret_key
